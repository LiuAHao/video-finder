# Video Finder Configuration

# Download directory
VIDEO_FINDER_DOWNLOAD_DIR=./downloads

# Database path
VIDEO_FINDER_DATABASE_PATH=./data/video_finder.sqlite

# Browser settings
VIDEO_FINDER_HEADLESS=true
VIDEO_FINDER_WAIT_SECONDS=10
VIDEO_FINDER_AUTO_CLICK=true

# Downloader settings
VIDEO_FINDER_DEFAULT_DOWNLOADER=auto
VIDEO_FINDER_CONCURRENCY=8
VIDEO_FINDER_FFMPEG_PATH=
VIDEO_FINDER_FFPROBE_PATH=

# Web server settings
VIDEO_FINDER_HOST=127.0.0.1
VIDEO_FINDER_PORT=7860

# User Agent (leave empty for default Chrome UA)
VIDEO_FINDER_USER_AGENT=

# Logging
VIDEO_FINDER_LOG_LEVEL=INFO
